# Database
DATABASE_URL=sqlite:///./localizer.db

# OpenAI-compatible API
# Leave OPENAI_API_KEY empty to use the app without AI features.
# OPENAI_BASE_URL defaults to https://api.openai.com/v1 if left empty.
# OPENAI_MODEL defaults to gpt-4o-mini if left empty.
OPENAI_API_KEY=
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# App
APP_NAME=JP Game Localizer MVP
DEBUG=true
